# OmniSight Environment Variables

# ==================== Database ====================
DATABASE_URL=postgresql://omnisight:omnisight_dev_password@localhost:5432/omnisight

# ==================== Vector Database ====================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=omnisight_dev_key

# ==================== Cache & Queue ====================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER=redis://localhost:6379/0

# ==================== Storage ====================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=omnisight
S3_SECRET_KEY=omnisight_dev_password
S3_BUCKET=omnisight-videos
S3_REGION=us-east-1

# ==================== API Configuration ====================
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE=OmniSight API
API_VERSION=0.1.0
LOG_LEVEL=info

# ==================== Authentication ====================
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== AI Models ====================
YOLO_MODEL=yolov11n
WHISPER_MODEL=base
EMBEDDING_MODEL=openai/clip-vit-base-patch32
LLM_MODEL=mistral

# ==================== Hardware ====================
ENABLE_GPU=false
DEVICE=cpu  # Options: cpu, cuda
NUM_WORKERS=4

# ==================== Features ====================
ENABLE_FACE_DETECTION=false
ENABLE_OCR=false
ENABLE_EMOTION_ANALYSIS=false

# ==================== Limits ====================
MAX_VIDEO_SIZE_GB=5
MAX_VIDEO_DURATION_MINUTES=180
MAX_CONCURRENT_UPLOADS=10
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ==================== Frontend ====================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=OmniSight

# ==================== Monitoring ====================
SENTRY_DSN=
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=9090

# ==================== Email (Optional) ====================
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@omnisight.dev
